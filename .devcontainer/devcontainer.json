{
  "name": "pag-profesor-ciencias",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "node",
  "postCreateCommand": "npm ci",
  "forwardPorts": [5173, 8888],
  "portsAttributes": {
    "5173": {
      "label": "Vite",
      "onAutoForward": "notify"
    },
    "8888": {
      "label": "Netlify Dev",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
